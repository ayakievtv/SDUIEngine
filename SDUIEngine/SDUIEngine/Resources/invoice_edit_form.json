{
   "id":"invoice_edit_form",
   "type":"VStack",
   "children":[
      {
         "id":"invoice_edit_root_scroll",
         "type":"ScrollView",
         "props":{
            "navigationTitle":"invoice_edit_form",
            "showsIndicators":false
         },
         "events":{
            "onAppear":{
               "target":"backend_data",
               "params":{
                  "actions":[
                     {
                        "target":"backend_data",
                        "action":"OPEN_FORM",
                        "formStatePrefix":"invoiceForm",
                        "endpoint":"https://oracleapex.com/ords/yakiev/sdui_example/invoices/{id}",
                        "idStateKey":"invoiceForm.id",
                        "clearPreviousDraft":"true"
                     }
                  ]
               }
            }
         },
         "children":[
            {
               "id":"invoice_edit_root_stack",
               "type":"VStack",
               "props":{
                  "padding":10,
                  "spacing":0
               },
               "children":[
                  {
                     "id":"invoice_doc_number_row",
                     "type":"HStack",
                     "children":[
                        {
                           "id":"invoice_doc_number_label",
                           "type":"Text",
                           "props":{
                              "text":"Document Number",
                              "fontSize":12,
                              "fontWeight":"semibold",
                              "color":"#5F676A",
                              "fixedSizeVertical":1
                           }
                        },
                        {
                           "id":"invoice_doc_number_spacer",
                           "type":"Spacer",
                           "props":{
                              "height":8
                           }
                        },
                        {
                           "id":"invoice_doc_number_field",
                           "type":"TextField",
                           "props":{
                              "placeholder":"Document Number",
                              "stateKey":"invoiceForm.doc_number",
                              "padding":10, "multilineTextAlignment":"right",
                              "maxLength": 100
                           }
                        }
                     ]
                  },
                  {
                     "id":"invoice_customer_row",
                     "type":"HStack",
                     "children":[
                        {
                           "id":"invoice_customer_label",
                           "type":"Text",
                           "props":{
                              "text":"Customer Name",
                              "fontSize":12,
                              "fontWeight":"semibold",
                              "color":"#5F676A",
                              "fixedSizeVertical":1
                           }
                        },
                        {
                           "id":"invoice_customer_spacer",
                           "type":"Spacer",
                           "props":{
                              "height":8
                           }
                        },
                        {
                           "id":"invoice_customer_field",
                           "type":"TextField",
                           "props":{
                              "placeholder":"Customer Name",
                              "stateKey":"invoiceForm.customer_name",
                              "padding":10, "multilineTextAlignment":"right"
                           
                           }
                        }
                     ]
                  },
                  {
                     "id":"invoice_amount_row",
                     "type":"HStack",
                     "children":[
                        {
                           "id":"invoice_row_title",
                           "type":"Text",
                           "props":{
                              "text":"Amount",
                              "fontSize":12,
                              "fontWeight":"semibold",
                              "color":"#5F676A",
                              "fixedSizeVertical":1
                           }
                        },
                        {
                           "id":"invoice_amount_spacer",
                           "type":"Spacer",
                           "props":{
                              "height":8
                           }
                        },
                        {
                           "id":"invoice_amount_field",
                           "type":"TextField",
                           "props":{
                              "placeholder":"Amount",
                              "stateKey":"invoiceForm.amount",
                              "padding":10, "multilineTextAlignment":"right"
                        
                           }
                        }
                     ]
                  },
                  {
                     "id":"invoice_doc_date_row",
                     "type":"HStack",
                     "children":[
                        {
                           "id":"invoice_doc_date_label",
                           "type":"Text",
                           "props":{
                              "text":"Document Date",
                              "fontSize":12,
                              "fontWeight":"semibold",
                              "color":"#5F676A",
                              "fixedSizeVertical":1
                           }
                        },
                        {
                           "id":"invoice_doc_date_spacer",
                           "type":"Spacer",
                           "props":{
                              "height":8
                           }
                        },
                        {
                           "id":"invoice_doc_date_field",
                           "type":"TextField",
                           "props":{
                              "placeholder":"Document Date (ISO)",
                              "stateKey":"invoiceForm.due_date",
                              "padding":10,
                              "multilineTextAlignment": "trailing"
                            
                           }
                        }
                     ]
                  },
                  {
                     "id":"invoice_status_row",
                     "type":"HStack",
                     "children":[
                        {
                           "id":"invoice_status_label",
                           "type":"Text",
                           "props":{
                              "text":"Status",
                              "fontSize":12,
                              "fontWeight":"semibold",
                              "color":"#5F676A",
                              "fixedSizeVertical":1
                           }
                        },
                        {
                           "id":"invoice_status_spacer",
                           "type":"Spacer",
                           "props":{
                              "height":8
                           }
                        },
                        {
                           "id":"invoice_status_field",
                           "type":"TextField",
                           "props":{
                              "placeholder":"Status",
                              "stateKey":"invoiceForm.status",
                              "padding":10,
                              "multilineTextAlignment":"right"
                            
                           }
                        }
                     ]
                  },
                  {
                     "id":"invoice_load_actions",
                     "type":"HStack",
                     "props":{
                        "spacing":8
                     },
                     "children":[
                        {
                           "id":"invoice_load_button",
                           "type":"Button",
                           "props":{
                              "title":"Load Invoice",
                              "padding":10,
                              "color":"#2563EB"
                           },
                           "events":{
                              "onTap":{
                                 "target":"backend_data",
                                 "params":{
                                    "actions":[
                                       {
                                          "target":"backend_data",
                                          "action":"OPEN_FORM",
                                          "endpoint":"https://oracleapex.com/ords/yakiev/sdui_example/invoices/{id}",
                                          "idStateKey":"invoiceForm.id",
                                          "clearPreviousDraft":"true"
                                       }
                                    ]
                                 }
                              }
                           }
                        },
                        {
                           "id":"invoice_refresh_button",
                           "type":"Button",
                           "props":{
                              "title":"Reload",
                              "padding":10,
                              "color":"#0EA5E9"
                           },
                           "events":{
                              "onTap":{
                                 "params":{
                                    "actions":[
                                       {
                                          "target":"backend_data",
                                          "action":"OPEN_FORM",
                                          "endpoint":"https://oracleapex.com/ords/yakiev/sdui_example/invoices/{id}",
                                          "idStateKey":"invoiceForm.id",
                                          "clearPreviousDraft":"true"
                                       }
                                    ]
                                 }
                              }
                           }
                        }
                     ]
                  },
                  {
                     "id":"invoice_save_actions",
                     "type":"HStack",
                     "props":{
                        "spacing":8
                     },
                     "children":[
                        {
                           "id":"invoice_save_post_button",
                           "type":"Button",
                           "props":{
                              "title":"Save (POST Queue)",
                              "padding":10,
                              "color":"#16A34A"
                           },
                           "events":{
                              "onTap":{
                                 "target":"backend_data",
                                 "params":{
                                    "actions":[
                                       {
                                          "target":"backend_data",
                                          "action":"SAVE_FORM",
                                          "endpoint":"https://oracleapex.com/ords/yakiev/sdui_example/invoices",
                                          "method":"POST",
                                          "queue":"true"
                                       }
                                    ]
                                 }
                              }
                           }
                        },
                        {
                           "id":"invoice_save_put_button",
                           "type":"Button",
                           "props":{
                              "title":"Save (PUT Queue)",
                              "padding":10,
                              "color":"#15803D"
                           },
                           "events":{
                              "onTap":{
                                 "params":{
                                    "actions":[
                                       {
                                          "target":"backend_data",
                                          "action":"SAVE_FORM",
                                          "endpoint":"https://oracleapex.com/ords/yakiev/sdui_example/invoices/{id}",
                                          "method":"PUT",
                                          "idStateKey":"invoiceForm.id",
                                          "queue":"true"
                                       }
                                    ]
                                 }
                              }
                           }
                        }
                     ]
                  },
                  {
                     "id":"invoice_discard_button",
                     "type":"Button",
                     "props":{
                        "title":"Close Without Save",
                        "padding":12,       "borderColor":"#0EA5E9",
                        "borderWidth":1,
                        "cornerRadius":12,
                        "color":"#DC2626"
                     },
                     "events":{
                        "onTap":{
                           "params":{
                              "actions":[
                                 {
                                    "target":"backend_data",
                                    "action":"DISCARD_FORM",
                                    "goBack":"true"
                                 }
                              ]
                           }
                        }
                     }
                  },
                  {
                     "id":"invoice_back_to_grid",
                     "type":"Button",
                     "props":{
                        "title":"Back To Invoices Grid",
                        "padding":12,
                        "color":"#0EA5E9",
                        "borderColor":"#0EA5E9",
                        "borderWidth":1,
                        "cornerRadius":12,
                        "backgroundColor":"#FFFFFF"
                     },
                     "events":{
                        "onTap":{
                           "params":{
                              "actions":[
                                 {
                                    "target":"navigation",
                                    "action":"push",
                                    "route":"invoices_grid"
                                 }
                              ]
                           }
                        }
                     }
                  }
               ]
            }
         ]
      }
   ]
}
