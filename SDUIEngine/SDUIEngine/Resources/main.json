{
   "id":"main",
   "type":"VStack",
   "props":{
      "padding":16,
      "spacing":12
   },
   "children":[
      {
         "id":"main_root_scroll",
         "type":"ScrollView",
         "props":{
            "navigationTitle":"Main",
            "showsIndicators":false
         },
         "children":[
            {
               "id":"title_text",
               "type":"Text",
               "props":{
                  "text":"Welcome to SDUIEngine",
                  "fontSize":26,
                  "fontWeight":"bold",
                  "color":"#5F2937"
               }
            },
            {
               "id":"go_demo_button",
               "type":"Button",
               "props":{
                  "title":"Open Demo Screen 1",
                  "padding":12,
                  "color":"#0EA5E9"
               },
               "events":{
                  "onTap":{
                     "params":{
                        "actions":[
                           {
                              "target":"navigation",
                              "action":"push",
                              "route":"demo_screen"
                           }
                        ]
                     }
                  }
               }
            },
            {
               "id":"go_demo2_button",
               "type":"Button",
               "props":{
                  "title":"Open Demo Screen 2",
                  "padding":12,
                  "color":"#14B8A6"
               },
               "events":{
                  "onTap":{
                     "params":{
                        "actions":[
                           {
                              "target":"navigation",
                              "action":"push",
                              "route":"demo_screen2"
                           }
                        ]
                     }
                  }
               }
            },
            {
               "id":"go_invoices_grid_button",
               "type":"Button",
               "props":{
                  "title":"Open Invoices Grid",
                  "padding":12,
                  "color":"#0284C7"
               },
               "events":{
                  "onTap":{
                     "params":{
                        "actions":[
                           {
                              "target":"navigation",
                              "action":"push",
                              "route":"invoices_grid"
                           }
                        ]
                     }
                  }
               }
            }
            
         ]
      }
   ]
}
