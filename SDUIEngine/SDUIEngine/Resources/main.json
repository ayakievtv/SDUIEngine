{
  "id": "root_stack",
  "type": "VStack",
  "props": {
    "padding": 16,
    "spacing": 12
  },
  "events": {},
  "children": [
    {
      "id": "title_text",
      "type": "Text",
      "props": {
        "text": "Welcome to SDUIEngine",
        "fontSize": 24,
        "fontWeight": "bold",
        "color": "#1F2937"
      },
      "events": {},
      "children": []
    },
    {
      "id": "cta_button",
      "type": "Button",
      "props": {
        "title": "Change Title Text",
        "padding": 12,
        "color": "#2563EB"
      },
      "events": {
        "onTap": {
          "target": "title_text",
          "params": {
            "action": "SET_TEXT",
            "value": "Title changed from cta_button"
          }
        }
      },
      "children": []
    },
    {
      "id": "color_button",
      "type": "Button",
      "props": {
        "title": "Change Title Color",
        "padding": 12,
        "color": "#059669"
      },
      "events": {
        "onTap": {
          "target": "title_text",
          "params": {
            "action": "SET_COLOR",
            "value": "#DC2626"
          }
        }
      },
      "children": []
    },
    {
      "id": "go_demo_button",
      "type": "Button",
      "props": {
        "title": "Open Second Screen",
        "padding": 12,
        "color": "#0EA5E9"
      },
      "events": {
        "onTap": {
          "target": "backend_navigation",
          "params": {
            "type": "navigate",
            "mode": "push",
            "route": "demo_screen"
          }
        }
      },
      "children": []
    }
  ]
}
