{
  "screen": {
    "id": "tabbar_demo",
    "type": "VStack",
    "props": {
      "padding": 0,
      "spacing": 0
    },
    "children": [
      {
        "id": "main_tabbar",
        "type": "TabBar",
        "props": {
          "selectedIndex": 0
        },
        "children": [
          {
            "id": "home_tab",
            "type": "VStack",
            "props": {
              "title": "Main",
              "systemImage": "house.fill"
            },
            "children": [
              {
                "id": "home_title",
                "type": "Text",
                "props": {
                  "text": "Main page",
                  "fontSize": 24,
                  "fontWeight": "bold",
                  "padding": 20
                }
              },
              {
                "id": "home_content",
                "type": "Text",
                "props": {
                  "text": "Welcome!",
                  "fontSize": 16,
                  "padding": 20
                }
              }
            ]
          },
          {
            "id": "invoices_tab",
            "type": "VStack",
            "props": {
              "title": "Invoices",
              "systemImage": "doc.text.fill"
            },
            "children": [
              {
                "id": "invoices_title",
                "type": "Text",
                "props": {
                  "text": "Invoices list",
                  "fontSize": 24,
                  "fontWeight": "bold",
                  "padding": 20
                }
              },
              {
                "id": "invoices_button",
                "type": "Button",
                "props": {
                  "text": "Open Invoices",
                  "padding": 20,
                  "color": "#0EA5E9",
                  "backgroundColor": "#EFF6FF",
                  "cornerRadius": 8
                },
                "events": {
                  "onTap":{
                     "params":{
                        "actions":[
                           {
                              "target":"navigation",
                              "action":"push",
                              "route":"invoices_grid"
                           }
                        ]
                     }
                  }
                }
              }
            ]
          },
          {
            "id": "profile_tab",
            "type": "VStack",
            "props": {
              "title": "Profile",
              "systemImage": "person.fill"
            },
            "children": [
              {
                "id": "profile_title",
                "type": "Text",
                "props": {
                  "text": "User profile",
                  "fontSize": 24,
                  "fontWeight": "bold",
                  "padding": 20
                }
              },
              {
                "id": "profile_info",
                "type": "Text",
                "props": {
                  "text": "Profile information will be here",
                  "fontSize": 16,
                  "padding": 20
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
